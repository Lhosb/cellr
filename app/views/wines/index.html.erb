<section class="space-y-4">
  <div class="flex gap-2 overflow-x-auto pb-1" style="scrollbar-width:none">
    <div class="stat-pill reveal reveal-d2">
      <span class="stat-pill__number"><%= @wines.size %></span>
      <span class="stat-pill__label">Wines</span>
    </div>
    <div class="stat-pill reveal reveal-d3">
      <span class="stat-pill__number"><%= @wines.map(&:cellar_id).uniq.size %></span>
      <span class="stat-pill__label">Cellars</span>
    </div>
    <% if drink_status_feature_enabled? %>
      <div class="stat-pill reveal reveal-d4">
        <span class="stat-pill__number" style="color: var(--color-sage)"><%= @wines.count { |wine| wine_drink_status_key(wine) == "ready" } %></span>
        <span class="stat-pill__label">Drink Soon</span>
      </div>
    <% end %>
  </div>

  <%= form_with url: root_path, method: :get, class: "space-y-2 reveal reveal-d1" do |form| %>
    <label class="search-bar">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" style="color:var(--color-ink-faint)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <%= form.search_field :q, value: params[:q], placeholder: "Wines, wineries, varietals…" %>
      <%= form.submit "Filter", class: "btn btn-xs" %>
    </label>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
      <%= form.text_field :winery, value: params[:winery], placeholder: "Winery", class: "input input-bordered input-sm w-full" %>
      <%= form.text_field :region, value: params[:region], placeholder: "Region", class: "input input-bordered input-sm w-full" %>
      <%= form.select :wine_type, options_for_select([["Any type", ""], ["Red", "red"], ["White", "white"], ["Rosé", "rosé"], ["Sparkling", "sparkling"], ["Dessert", "dessert"], ["Fortified", "fortified"]], params[:wine_type]), {}, class: "select select-bordered select-sm w-full" %>
    </div>
  <% end %>

  <div class="flex gap-2 overflow-x-auto pb-1" style="scrollbar-width:none">
    <% chip_types = [["All", ""], ["Red", "red"], ["White", "white"], ["Rosé", "rosé"], ["Sparkling", "sparkling"], ["Dessert", "dessert"], ["Fortified", "fortified"]] %>
    <% chip_types.each do |label, value| %>
      <% selected = params[:wine_type].to_s == value.to_s %>
      <%= link_to label, request.query_parameters.merge(wine_type: value.presence).compact, class: "chip #{selected ? 'chip--active' : ''}" %>
    <% end %>
    <%= link_to "Reset", root_path, class: "chip" %>
  </div>

  <div class="flex items-baseline justify-between pt-1">
    <h1 class="font-display text-2xl font-bold italic">In the cellar</h1>
    <span class="text-xs" style="color:var(--color-ink-faint)"><%= pluralize(@wines.size, "result") %></span>
  </div>

  <% if @wines.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @wines.each_with_index do |wine, index| %>
        <article class="wine-card reveal reveal-d<%= [(index % 5) + 1, 5].min %>">
          <div class="wine-card__vintage-watermark"><%= wine.vintage || "NV" %></div>
          <div class="wine-card__body">
            <div class="flex items-start justify-between gap-2 mb-3">
              <div>
                <div class="type-pill <%= wine_type_pill_class(wine.wine_type) %> mb-2">
                  <span class="type-pill__dot <%= wine_type_dot_class(wine.wine_type) %>"></span>
                  <%= wine.wine_type.presence || wine.varietal.presence || "Wine" %>
                </div>
                <h2 class="font-display text-xl font-bold leading-tight"><%= wine.wine_name %></h2>
                <p class="text-xs mt-0.5" style="color:var(--color-ink-light)"><%= [wine.winery, wine.region.presence].compact.join(" · ") %></p>
              </div>
              <div class="wine-card__quantity">×1</div>
            </div>

            <div class="wine-card__divider"></div>

            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-xs" style="color:var(--color-ink-light)">
                <span><%= wine.purchase_price_cents.present? ? number_to_currency(wine.purchase_price_cents / 100.0) : "—" %> / btl</span>
                <span style="color:var(--color-ink-faint)">·</span>
                <%= link_to wine.cellar.name, cellar_path(wine.cellar), class: "underline-offset-2 hover:underline" %>
              </div>
              <% if drink_status_feature_enabled? %>
                <span class="drink-status drink-status--<%= wine_drink_status_key(wine) %>">
                  <span class="drink-status__dot"></span>
                  <span><%= wine_drink_status_label(wine) %></span>
                </span>
              <% end %>
            </div>

            <% if drink_status_feature_enabled? %>
              <div class="drink-window">
                <div class="drink-window__fill <%= wine_drink_status_key(wine) == 'aging' ? 'drink-window__fill--aging' : '' %>" style="width:<%= wine_drink_status_key(wine) == 'ready' ? 82 : 34 %>%"></div>
              </div>
            <% end %>

            <% if wine.tags.any? %>
              <div class="flex gap-1.5 mt-2.5 flex-wrap">
                <% wine.tags.each do |tag| %>
                  <%= link_to tag.name, request.query_parameters.merge(tag: tag.name.downcase), class: "chip", style: "padding:0.15rem 0.55rem;font-size:0.6rem" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="wine-card">
      <div class="wine-card__body">
        <p class="text-sm" style="color:var(--color-ink-light)">No wines found yet.</p>
      </div>
    </div>
  <% end %>
</section>
