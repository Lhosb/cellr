<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cellr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="light">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cellr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-theme="cellr">
    <div class="app-shell">
      <header class="masthead">
        <div class="masthead-rule"></div>
        <div class="px-5 py-4 flex items-center justify-between gap-3">
          <div class="reveal reveal-d1">
            <div class="flex items-baseline gap-2">
              <%= link_to "Cellr", root_path, class: "font-display text-3xl font-bold tracking-tight text-base-100" %>
            </div>
          </div>

          <div class="flex items-center gap-2 reveal reveal-d2">
            <% if user_signed_in? %>
              <%= link_to "Wines", root_path, class: "btn btn-xs border-0 bg-base-100/10 text-base-100 hover:bg-base-100/20" %>
              <%= link_to "Cellars", cellars_path, class: "btn btn-xs border-0 bg-base-100/10 text-base-100 hover:bg-base-100/20" %>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-xs border-0 bg-base-100/10 text-base-100 hover:bg-base-100/20" %>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "btn btn-xs border-0 bg-base-100/10 text-base-100 hover:bg-base-100/20" %>
            <% end %>
          </div>
        </div>
      </header>

      <main class="page-content">
        <% if notice.present? %>
          <div class="alert alert-success mb-4">
            <span><%= notice %></span>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="alert alert-error mb-4">
            <span><%= alert %></span>
          </div>
        <% end %>

        <%= yield %>
      </main>

      <nav class="bottom-nav" aria-label="Primary">
        <div class="bottom-nav__items">
          <%= link_to root_path, class: "nav-item #{current_page?(root_path) ? 'nav-item--active' : ''}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>Wines</span>
          <% end %>

          <%= link_to cellars_path, class: "nav-item #{current_page?(cellars_path) ? 'nav-item--active' : ''}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 7h18M5 7v12a1 1 0 001 1h12a1 1 0 001-1V7m-8 4h4m-4 4h6" />
            </svg>
            <span>Cellars</span>
          <% end %>

          <% if user_signed_in? %>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-item" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
              </svg>
              <span>Sign Out</span>
            <% end %>
          <% end %>
        </div>
      </nav>
    </div>
  </body>
</html>
