<section class="space-y-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h1 class="font-display text-2xl font-bold"><%= @cellar.name %></h1>
      <p class="text-sm" style="color:var(--color-ink-light)">Owner · <%= @cellar.owner.email %></p>
    </div>
    <%= link_to "Back", cellars_path, class: "btn btn-sm" %>
  </div>

  <div class="flex gap-2 overflow-x-auto pb-1" style="scrollbar-width:none">
    <div class="stat-pill reveal reveal-d2">
      <span class="stat-pill__number"><%= @wines.size %></span>
      <span class="stat-pill__label">Wines</span>
    </div>
    <% if drink_status_feature_enabled? %>
      <div class="stat-pill reveal reveal-d4">
        <span class="stat-pill__number" style="color: var(--color-sage)"><%= @wines.count { |wine| wine_drink_status_key(wine) == "ready" } %></span>
        <span class="stat-pill__label">Drink Soon</span>
      </div>
    <% end %>
  </div>

  <%= form_with url: cellar_path(@cellar), method: :get, class: "space-y-2 reveal reveal-d1" do |form| %>
    <label class="search-bar">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" style="color:var(--color-ink-faint)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <%= form.search_field :q, value: params[:q], placeholder: "Wines, wineries, varietals…" %>
      <%= form.submit "Filter", class: "btn btn-xs" %>
    </label>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
      <%= form.text_field :winery, value: params[:winery], placeholder: "Winery", class: "input input-bordered input-sm w-full" %>
      <%= form.text_field :region, value: params[:region], placeholder: "Region", class: "input input-bordered input-sm w-full" %>
      <%= form.select :wine_type, options_for_select([["Any type", ""], ["Red", "red"], ["White", "white"], ["Rosé", "rosé"], ["Sparkling", "sparkling"], ["Dessert", "dessert"], ["Fortified", "fortified"]], params[:wine_type]), {}, class: "select select-bordered select-sm w-full" %>
    </div>
  <% end %>

  <div class="flex gap-2 overflow-x-auto pb-1" style="scrollbar-width:none">
    <% chip_types = [["All", ""], ["Red", "red"], ["White", "white"], ["Rosé", "rosé"], ["Sparkling", "sparkling"], ["Dessert", "dessert"], ["Fortified", "fortified"]] %>
    <% chip_types.each do |label, value| %>
      <% selected = params[:wine_type].to_s == value.to_s %>
      <%= link_to label, request.query_parameters.merge(wine_type: value.presence).compact, class: "chip #{selected ? 'chip--active' : ''}" %>
    <% end %>
    <%= link_to "Reset", cellar_path(@cellar), class: "chip" %>
  </div>

  <details class="wine-card details-toggle">
    <summary class="wine-card__body cursor-pointer flex items-center justify-between list-none">
      <h2 class="font-display text-lg font-semibold">Add Wine</h2>
      <span class="details-toggle__indicator" aria-hidden="true">
        <span class="details-toggle__plus">+</span>
        <span class="details-toggle__minus">−</span>
      </span>
    </summary>

    <div class="wine-card__body space-y-3 pt-0" data-controller="wine-scan" data-wine-scan-endpoint-value="<%= scan_cellar_wine_label_path(@cellar) %>">

      <div>
        <label class="label"><span class="label-text">Label photo</span></label>
        <div class="flex flex-wrap gap-2">
          <label for="wine-label-image" class="btn btn-sm">Scan a Bottle</label>
        </div>
        <input id="wine-label-image" type="file" class="sr-only" accept="image/*" data-wine-scan-target="image" data-action="change->wine-scan#imageSelected">
      </div>
      <p class="text-xs" style="color:var(--color-ink-light)" data-wine-scan-target="status"></p>

      <%= form_with url: cellar_wines_path(@cellar), method: :post, scope: :wine, class: "grid grid-cols-1 gap-2" do |form| %>
        <div>
          <label class="label"><span class="label-text">Winery</span></label>
          <%= form.text_field :winery, required: true, class: "input input-bordered input-sm w-full", data: { wine_scan_target: "winery" } %>
        </div>

        <div>
          <label class="label"><span class="label-text">Wine name</span></label>
          <%= form.text_field :wine_name, required: true, class: "input input-bordered input-sm w-full", data: { wine_scan_target: "wineName" } %>
        </div>

        <div>
          <label class="label"><span class="label-text">Varietal</span></label>
          <%= form.text_field :varietal, class: "input input-bordered input-sm w-full", data: { wine_scan_target: "varietal" } %>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="label"><span class="label-text">Vintage</span></label>
            <%= form.number_field :vintage, min: 1900, max: 2100, class: "input input-bordered input-sm w-full", data: { wine_scan_target: "vintage" } %>
          </div>
          <div>
            <label class="label"><span class="label-text">Wine type</span></label>
            <%= form.select :wine_type, options_for_select([["", ""], ["Red", "red"], ["White", "white"], ["Rosé", "rosé"], ["Sparkling", "sparkling"], ["Dessert", "dessert"], ["Fortified", "fortified"]]), {}, class: "select select-bordered select-sm w-full", data: { wine_scan_target: "wineType" } %>
          </div>
        </div>

        <div>
          <label class="label"><span class="label-text">Region</span></label>
          <%= form.text_field :region, class: "input input-bordered input-sm w-full", data: { wine_scan_target: "region" } %>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="label"><span class="label-text">Bottle size</span></label>
            <%= form.select :bottle_size_ml, options_for_select(bottle_size_options, 750), {}, class: "select select-bordered select-sm w-full", data: { wine_scan_target: "bottleSizeMl" } %>
          </div>
          <div>
            <label class="label"><span class="label-text">Purchase price ($)</span></label>
            <%= form.number_field :purchase_price, step: 0.01, min: 0, placeholder: "0.00", class: "input input-bordered input-sm w-full" %>
          </div>
        </div>

        <div>
          <label class="label"><span class="label-text">Tags (comma-separated)</span></label>
          <%= form.text_field :tag_list, placeholder: "date night, special, gift", class: "input input-bordered input-sm w-full" %>
        </div>

        <%= form.submit "Add Wine", class: "btn btn-sm btn-primary" %>
      <% end %>
    </div>
  </details>

  <section class="wine-card">
    <div class="wine-card__body space-y-3">
      <div class="flex items-center justify-between gap-2">
        <h2 class="font-display text-lg font-semibold">Invite People</h2>
        <span class="text-xs" style="color:var(--color-ink-faint)"><%= pluralize(@memberships.size, "member") %></span>
      </div>

      <% if @can_manage_sharing %>
        <%= form_with url: cellar_invitations_path(@cellar), method: :post, class: "grid grid-cols-1 sm:grid-cols-[1fr_140px_auto] gap-2" do %>
          <%= hidden_field_tag :invited_by_id, current_user.id %>
          <%= email_field_tag :email, nil, required: true, placeholder: "friend@example.com", class: "input input-bordered input-sm w-full" %>
          <%= select_tag :role, options_for_select([["Co-Owner", "editor"], ["Viewer", "viewer"]], "editor"), class: "select select-bordered select-sm w-full" %>
          <%= submit_tag "Send Invite", class: "btn btn-sm" %>
        <% end %>
      <% else %>
        <p class="text-xs" style="color:var(--color-ink-light)">You have view-only access to this cellar.</p>
      <% end %>

      <% if @pending_invitations.any? %>
        <div class="space-y-1.5">
          <p class="text-xs uppercase tracking-wide" style="color:var(--color-ink-faint)">Pending invites</p>
          <% @pending_invitations.each do |invitation| %>
            <div class="flex items-center justify-between gap-2 p-2 rounded-lg" style="background: var(--color-parchment)">
              <div class="min-w-0">
                <p class="text-sm truncate"><%= invitation.email %></p>
                <p class="text-xs" style="color:var(--color-ink-light)"><%= invitation.role.titleize %></p>
                <p class="text-xs truncate" style="color:var(--color-ink-faint)"><%= cellar_invitation_token_url(invitation.token) %></p>
              </div>
              <% if @can_manage_sharing %>
                <%= button_to "Revoke", cellar_invitation_path(@cellar, invitation), method: :delete, class: "btn btn-xs" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <div class="flex items-baseline justify-between pt-1">
    <h2 class="font-display text-2xl font-bold italic">In the cellar</h2>
    <span class="text-xs" style="color:var(--color-ink-faint)"><%= pluralize(@wines.size, "result") %></span>
  </div>

  <% if @wines.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @wines.each_with_index do |wine, index| %>
        <%= link_to edit_cellar_wine_path(@cellar, wine), class: "wine-card reveal reveal-d#{[(index % 5) + 1, 5].min}" do %>
          <div class="wine-card__vintage-watermark"><%= wine.vintage || "NV" %></div>
          <div class="wine-card__body">
            <div class="flex items-start justify-between gap-2 mb-3">
              <div>
                <div class="type-pill <%= wine_type_pill_class(wine.wine_type) %> mb-2">
                  <span class="type-pill__dot <%= wine_type_dot_class(wine.wine_type) %>"></span>
                  <%= wine.wine_type.presence || wine.varietal.presence || "Wine" %>
                </div>
                <h3 class="font-display text-xl font-bold leading-tight"><%= wine.wine_name %></h3>
                <p class="text-xs mt-0.5" style="color:var(--color-ink-light)"><%= [wine.winery, wine.region.presence].compact.join(" · ") %></p>
              </div>
              <div class="wine-card__quantity">×1</div>
            </div>

            <div class="wine-card__divider"></div>

            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-xs" style="color:var(--color-ink-light)">
                <span><%= wine.purchase_price_cents.present? ? number_to_currency(wine.purchase_price_cents / 100.0) : "—" %> / btl</span>
                <span style="color:var(--color-ink-faint)">·</span>
                <span><%= @cellar.name %></span>
              </div>
              <% if drink_status_feature_enabled? %>
                <span class="drink-status drink-status--<%= wine_drink_status_key(wine) %>">
                  <span class="drink-status__dot"></span>
                  <span><%= wine_drink_status_label(wine) %></span>
                </span>
              <% end %>
            </div>

            <% if drink_status_feature_enabled? %>
              <div class="drink-window">
                <div class="drink-window__fill <%= wine_drink_status_key(wine) == 'aging' ? 'drink-window__fill--aging' : '' %>" style="width:<%= wine_drink_status_key(wine) == 'ready' ? 82 : 34 %>%"></div>
              </div>
            <% end %>

            <% if wine.tags.any? %>
              <div class="flex gap-1.5 mt-2.5 flex-wrap">
                <% wine.tags.each do |tag| %>
                  <span class="chip" style="padding:0.15rem 0.55rem;font-size:0.6rem"><%= tag.name %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="wine-card">
      <div class="wine-card__body">
        <p class="text-sm" style="color:var(--color-ink-light)">No wines found yet.</p>
      </div>
    </div>
  <% end %>
</section>