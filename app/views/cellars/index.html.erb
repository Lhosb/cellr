<section class="space-y-4">
  <div class="flex items-baseline justify-between">
    <h1 class="font-display text-2xl font-bold italic">Cellars</h1>
    <span class="text-xs" style="color:var(--color-ink-faint)"><%= pluralize(@cellars.size, "cellar") %></span>
  </div>

  <article class="wine-card">
    <div class="wine-card__body">
      <h2 class="font-display text-lg font-semibold mb-3">Create Cellar</h2>
      <% if @user.present? %>
        <%= form_with url: cellars_path, method: :post, class: "grid grid-cols-1 md:grid-cols-3 gap-3 items-end" do |form| %>
          <%= form.text_field :name, required: true, placeholder: "Cellar name", class: "input input-bordered w-full" %>
          <div class="text-sm" style="color:var(--color-ink-light)">
            Owner · <%= @user.email %>
          </div>
          <%= form.submit "Create", class: "btn btn-primary" %>
        <% end %>
      <% else %>
        <p class="text-sm" style="color:var(--color-ink-light)">Sign in to create a cellar.</p>
      <% end %>
    </div>
  </article>

  <% if @pending_invitations.any? %>
    <div class="space-y-2">
      <h2 class="font-display text-lg font-semibold">Pending Invitations</h2>
      <% @pending_invitations.each do |invitation| %>
        <article class="wine-card">
          <div class="wine-card__body flex items-center justify-between gap-3">
            <div>
              <h3 class="font-display font-bold"><%= invitation.cellar.name %></h3>
              <p class="text-xs" style="color:var(--color-ink-light)">
                Invited by <%= invitation.invited_by.email %> as <strong><%= invitation.role.titleize %></strong>
              </p>
            </div>
            <div class="flex gap-2">
              <%= button_to "Accept", accept_cellar_invitation_path(invitation.token), method: :post, class: "btn btn-sm btn-primary" %>
              <%= link_to "View", cellar_invitation_token_path(invitation.token), class: "btn btn-sm" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>

  <% if @cellars.any? %>
    <div class="grid grid-cols-1 gap-3">
      <% default_cellar_id = current_user.cellar_memberships.default_for_user.pick(:cellar_id) %>
      <% @cellars.each_with_index do |cellar, index| %>
        <article class="wine-card reveal reveal-d<%= [(index % 5) + 1, 5].min %>">
          <div class="wine-card__body">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h2 class="font-display text-xl font-bold"><%= cellar.name %></h2>
                <p class="text-xs mt-1" style="color:var(--color-ink-light)">Owner · <%= cellar.owner.email %></p>
                <% if cellar.id == default_cellar_id %>
                  <span class="chip chip--active mt-1" style="font-size:0.6rem;padding:0.1rem 0.5rem">Default</span>
                <% end %>
              </div>
              <%= link_to "Open", cellar_path(cellar), class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <article class="wine-card">
      <div class="wine-card__body">
        <p class="text-sm" style="color:var(--color-ink-light)">No cellars available yet.</p>
      </div>
    </article>
  <% end %>
</section>