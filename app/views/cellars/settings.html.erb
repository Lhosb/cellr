<section class="space-y-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h1 class="font-display text-2xl font-bold">Cellar Settings</h1>
      <p class="text-sm" style="color:var(--color-ink-light)"><%= @cellar.name %></p>
    </div>
    <%= link_to "Back", cellar_path(@cellar), class: "btn btn-sm" %>
  </div>

  <section class="wine-card">
    <div class="wine-card__body space-y-3">
      <h2 class="font-display text-lg font-semibold">Edit Cellar Name</h2>
      <%= form_with url: cellar_path(@cellar), method: :patch, class: "grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-2 items-end" do %>
        <div>
          <label class="label"><span class="label-text">Rename cellar</span></label>
          <%= text_field_tag :name, @cellar.name, required: true, class: "input input-bordered input-sm w-full", placeholder: "Cellar name" %>
        </div>
        <%= submit_tag "Save Name", class: "btn btn-sm" %>
      <% end %>
    </div>
  </section>

  <section class="wine-card">
    <div class="wine-card__body space-y-3">
      <div class="flex items-center justify-between gap-2">
        <h2 class="font-display text-lg font-semibold">Invite People</h2>
        <span class="text-xs" style="color:var(--color-ink-faint)"><%= pluralize(@memberships.size, "member") %></span>
      </div>

      <% if @can_manage_sharing %>
        <%= form_with url: cellar_invitations_path(@cellar), method: :post, class: "grid grid-cols-1 sm:grid-cols-[1fr_140px_auto] gap-2" do %>
          <%= hidden_field_tag :invited_by_id, current_user.id %>
          <%= email_field_tag :email, nil, required: true, placeholder: "friend@example.com", class: "input input-bordered input-sm w-full" %>
          <%= select_tag :role, options_for_select([["Co-Owner", "editor"], ["Viewer", "viewer"]], "editor"), class: "select select-bordered select-sm w-full" %>
          <%= submit_tag "Send Invite", class: "btn btn-sm" %>
        <% end %>
      <% else %>
        <p class="text-xs" style="color:var(--color-ink-light)">You have view-only access to this cellar.</p>
      <% end %>

      <% if @pending_invitations.any? %>
        <div class="space-y-1.5">
          <p class="text-xs uppercase tracking-wide" style="color:var(--color-ink-faint)">Pending invites</p>
          <% @pending_invitations.each do |invitation| %>
            <div class="flex items-center justify-between gap-2 p-2 rounded-lg" style="background: var(--color-parchment)">
              <div class="min-w-0">
                <p class="text-sm truncate"><%= invitation.email %></p>
                <p class="text-xs" style="color:var(--color-ink-light)"><%= invitation.role.titleize %></p>
                <p class="text-xs truncate" style="color:var(--color-ink-faint)"><%= cellar_invitation_token_url(invitation.token) %></p>
              </div>
              <% if @can_manage_sharing %>
                <%= button_to "Revoke", cellar_invitation_path(@cellar, invitation), method: :delete, class: "btn btn-xs" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
</section>
