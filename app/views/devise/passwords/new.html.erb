<section class="space-y-4 max-w-xl mx-auto">
  <div class="flex items-baseline justify-between">
    <h1 class="font-display text-2xl font-bold italic">Reset password</h1>
  </div>

  <article class="wine-card">
    <div class="wine-card__body space-y-3">
      <% if resource.errors.any? %>
        <div class="alert alert-error">
          <span><%= resource.errors.full_messages.to_sentence %></span>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "grid grid-cols-1 gap-3" }) do |f| %>
        <div>
          <label class="label"><span class="label-text">Email</span></label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
        </div>

        <%= f.submit "Send reset instructions", class: "btn btn-primary" %>
      <% end %>

      <%= render "devise/shared/auth_links" %>
    </div>
  </article>
</section>
