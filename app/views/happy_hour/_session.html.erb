<% session_records = session.drinking_records.sort_by(&:consumed_at).reverse %>
<% latest_record = session_records.first %>

<article id="<%= dom_id(session) %>" class="wine-card happy-hour-card">
  <div class="wine-card__body space-y-2">
    <div class="flex items-center justify-between gap-2">
      <h2 class="font-display text-xl font-bold"><%= session.user.name.presence || "Mystery Sipper" %></h2>
      <span class="chip chip--active"><%= session.status_label %></span>
    </div>

    <% if session_records.any? %>
      <% latest_wine = latest_record.cellar_entry %>
      <details class="details-toggle happy-hour-records">
        <summary class="happy-hour-records__summary-row list-none cursor-pointer flex items-center justify-between gap-2">
          <div class="min-w-0">
            <p class="happy-hour-records__label">Recent pours · <%= pluralize(session_records.size, "bottle") %></p>
            <p class="happy-hour-records__headline">
              <%= [wine_winery_name(latest_wine), latest_wine&.wine_name].compact_blank.join(" · ").presence || "Mystery pour" %>
            </p>
          </div>
          <span class="details-toggle__indicator" aria-hidden="true">
            <span class="details-toggle__plus">+</span>
            <span class="details-toggle__minus">−</span>
          </span>
        </summary>

        <ul class="space-y-2 happy-hour-list">
          <% session_records.each do |record| %>
            <% wine = record.cellar_entry %>
            <% winery_name = wine_winery_name(wine).presence || "Unknown winery" %>
            <% wine_name = wine&.wine_name.presence || "Mystery pour" %>
            <li class="happy-hour-list__item" style="color:var(--color-ink-light)">
              <article class="happy-hour-pour">
                <p class="happy-hour-pour__winery"><%= winery_name %></p>
                <p class="happy-hour-pour__wine">
                  <%= wine_name %>
                  <% if wine&.vintage.present? %>
                    <span class="happy-hour-pour__vintage">· <%= wine.vintage %></span>
                  <% end %>
                </p>
                <div class="happy-hour-pour__meta">
                  <span><%= time_ago_in_words(record.consumed_at) %> ago</span>
                  <% if latest_record.id == record.id %>
                    <span class="chip chip--active">🥂 Currently drinking</span>
                  <% end %>
                </div>
              </article>
            </li>
          <% end %>
        </ul>
      </details>
    <% else %>
      <p class="text-sm" style="color:var(--color-ink-light)">Just started — no drinks logged yet.</p>
    <% end %>
  </div>
</article>