<section class="space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-display text-2xl font-bold">Admin — Cellars</h1>
      <p class="text-sm" style="color:var(--color-ink-light)">All cellars in the application. Click a cellar to view its public page.</p>
    </div>
    <%= link_to "Back", profile_path, class: "btn btn-sm" %>
  </div>

  <% if @cellars.any? %>
    <div class="space-y-3">
      <% @cellars.each do |cellar| %>
        <div class="wine-card">
          <div class="wine-card__body">
            <div class="flex items-start justify-between">
              <div>
                <h2 class="font-medium"><%= link_to cellar.name, cellar_path(cellar), class: "underline" %></h2>
                <p class="text-sm" style="color:var(--color-ink-light)">Owner: <%= cellar.owner.name.presence || cellar.owner.email %></p>
                <p class="text-sm" style="color:var(--color-ink-light)">Members: <%= cellar.cellar_memberships.count %></p>
              </div>
              <div class="text-right">
                <div class="text-sm" style="color:var(--color-ink-light)"><%= time_ago_in_words(cellar.created_at) %> ago</div>
                <%= link_to "View", cellar_path(cellar), class: "btn btn-sm btn-outline mt-2" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm" style="color:var(--color-ink-light)">No cellars found.</p>
  <% end %>
</section>
