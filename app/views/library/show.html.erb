<section class="space-y-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h1 class="font-display text-2xl font-bold">Library</h1>
      <p class="text-sm" style="color:var(--color-ink-light)">Consumption totals across your shared cellar history.</p>
    </div>
    <%= link_to "Back", cellars_path, class: "btn btn-sm" %>
  </div>

  <%= form_with url: library_path, method: :get, class: "wine-card" do |form| %>
    <div class="wine-card__body space-y-2">
      <h2 class="font-display text-lg font-semibold">Vintage Breakdown</h2>
      <p class="text-xs" style="color:var(--color-ink-light)">Pick a wine to see bottles consumed by vintage.</p>
      <div class="flex items-center gap-2">
        <%= form.select :wine_id,
                        options_for_select(@wine_totals.map { |row| ["#{row.winery_name} - #{row.wine_name}", row.wine_id] }, @selected_wine_id),
                        { include_blank: "Select a wine" },
                        class: "select select-bordered select-sm w-full" %>
        <%= form.submit "Show", class: "btn btn-sm" %>
      </div>
    </div>
  <% end %>

  <% if @selected_wine.present? && @wine_vintage_totals.present? %>
    <div class="wine-card">
      <div class="wine-card__body space-y-2">
        <h2 class="font-display text-lg font-semibold"><%= @selected_wine.winery.name %> - <%= @selected_wine.name %></h2>
        <ul class="space-y-1">
          <% @wine_vintage_totals.each do |row| %>
            <li class="flex items-center justify-between text-sm">
              <span><%= row.vintage.presence || "Unknown / NV" %></span>
              <strong><%= pluralize(row.bottles_drank.to_i, "bottle") %></strong>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="wine-card">
      <div class="wine-card__body space-y-2">
        <h2 class="font-display text-lg font-semibold">Bottles Drank by Wine</h2>
        <% if @wine_totals.any? %>
          <ul class="space-y-1">
            <% @wine_totals.each do |row| %>
              <li class="flex items-center justify-between text-sm gap-2">
                <%= link_to "#{row.winery_name} - #{row.wine_name}", library_path(wine_id: row.wine_id), class: "underline decoration-dotted" %>
                <strong><%= row.bottles_drank.to_i %></strong>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm" style="color:var(--color-ink-light)">No consumption records yet.</p>
        <% end %>
      </div>
    </div>

    <div class="wine-card">
      <div class="wine-card__body space-y-2">
        <h2 class="font-display text-lg font-semibold">Bottles Drank by Winery</h2>
        <% if @winery_totals.any? %>
          <ul class="space-y-1">
            <% @winery_totals.each do |row| %>
              <li class="flex items-center justify-between text-sm gap-2">
                <span><%= row.winery_name %></span>
                <strong><%= row.bottles_drank.to_i %></strong>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm" style="color:var(--color-ink-light)">No consumption records yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>